# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# --- Backend (Python / Django or FastAPI) ---
# 가상환경 무시 (가장 중요!)
backend/venv/
venv/
ENV/
env/

backend/.env

# 파이썬 캐시 파일
**/__pycache__/
*.py[cod]
*$py.class

# 로컬 설정 및 환경변수
backend/.env
.env

# 데이터베이스 (SQLite 등 로컬 DB)
*.sqlite3
*.db


# --- Frontend (React) ---
# dependencies - 프론트엔드 라이브러리 무시
frontend/node_modules/
frontend/.pnp
frontend/.pnp.js

# testing - 테스트 결과물 무시
frontend/coverage/

# production - 빌드 결과물 무시
frontend/build/


# --- Misc / OS ---
# 운영체제 생성 파일
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# IDE 설정 (VS Code, IntelliJ 등)
.vscode/
.idea/
*.swp
*.bak

# 로컬 환경변수 파일들
.env.local
.env.development.local
.env.test.local
.env.production.local

# logs - 로그 파일 무시
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# --- DeepEye Project Specific ---
# 분석 결과 이미지 (매번 생성되므로 Git에 올릴 필요 없음)
backend/static/lime_*.png

# 모델 파일 (용량이 크므로 팀원 간 별도 공유 권장)
backend/models/*.pth
*.pth
*.h5

# 임시 영상 파일 (분석 시 생성되는 임시 파일)
backend/temp_*.mp4